<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  VO Edit Event + Save as Draft (standalone)

  Flow: Org Login → View More → Org → Events → Edit Event → Save as Draft → Logout

  Run:
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-vo-edit-event.xml
-->
<suite name="VO Edit Event" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="VO Edit Event Flow" preserve-order="true">
        <classes>
            <class name="com.mybharat.tests.vo.VOLoginTest"/>
            <class name="com.mybharat.tests.vo.VOEventEditTest"/>
        </classes>
    </test>

</suite>
