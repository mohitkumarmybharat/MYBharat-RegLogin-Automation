<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ALL MODULES - Runs Public Pages in PARALLEL with the main user flow.
  
  Thread 1: Public Pages (independent, own browser)
  Thread 2: Registration → Logout → Login → Profile → Certificate → Basic Info → Quiz → Quiz Certificate
  
  Both threads run simultaneously, reducing total execution time.
  Report and email content display all results together as before.
  
  Run with:
    mvn test "-Denv=prod" "-Dbrowser=chrome" "-Dsurefire.suiteXmlFiles=testSuites/testng-all-modules.xml"
-->
<suite name="MYBharat All Modules" parallel="tests" thread-count="2" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- PARALLEL THREAD 1: Public Page validation (independent, own browser) -->
    <test name="Public Page">
        <classes>
            <class name="com.mybharat.tests.youth.PublicPageTest"/>
        </classes>
    </test>

    <!-- PARALLEL THREAD 2: Sequential user flow (shared browser session) -->
    <test name="Youth Flow">
        <classes>
            <!-- Step 1: Registration -->
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
            <!-- Step 2: Logout -->
            <class name="com.mybharat.tests.youth.LogoutTest"/>
            <!-- Step 3: Login -->
            <class name="com.mybharat.tests.youth.LoginTest"/>
            <!-- Step 4: Profile -->
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
            <!-- Step 5: Registration Certificate -->
            <class name="com.mybharat.tests.youth.RegistrationCertificateVerificationTest"/>
            <!-- Step 6: Basic Info -->
            <class name="com.mybharat.tests.youth.BasicInfoTest"/>
            <!-- Step 7: Quiz -->
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
            <!-- Step 8: Quiz Certificate -->
            <class name="com.mybharat.tests.youth.QuizCertificateVerificationTest"/>
        </classes>
    </test>

</suite>
