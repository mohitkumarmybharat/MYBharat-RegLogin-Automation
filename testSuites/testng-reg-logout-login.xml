<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ============================================================
  Registration → Logout → Login (Single Class, Single Session)
  ============================================================
  Purpose: Runs the full Registration → Logout → Login flow in one browser session.
  
  Flow:
    1. Register new Indian youth (email + OTP + form + submit)
    2. Logout (clear session)
    3. Login with OTP (using email saved in Excel)
  
  Run:
    mvn test -Denv=beta -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-reg-logout-login.xml
    mvn test -Denv=prod -Dbrowser=headless -DciMode=true -Dsurefire.suiteXmlFiles=testSuites/testng-reg-logout-login.xml
  
  Team: QA Team
  ============================================================
-->
<suite name="Registration-Logout-Login" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Register Logout Login Flow">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationLogoutLoginTest"/>
        </classes>
    </test>

</suite>
