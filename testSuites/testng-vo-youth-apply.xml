<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  VO Youth Apply - Youth applies on a published VO event
  
  Flow: Login (maynak@yopmail.com) → Volunteer for Bharat → Search Event → Apply → Upload Images

  Run:
    mvn test -Denv=prod -Dbrowser=chrome -DvoExcelPrefix=VO_Youth -Dsurefire.suiteXmlFiles=testSuites/testng-vo-youth-apply.xml
-->
<suite name="VO Youth Apply" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Step 1: Login as Youth VO user (from VO_Youth_<env>.xlsx) -->
    <test name="VO Youth Login">
        <classes>
            <class name="com.mybharat.tests.vo.VOLoginTest"/>
        </classes>
    </test>

    <!-- Step 2: Youth applies on VO event and uploads images -->
    <test name="Youth Apply on VO">
        <classes>
            <class name="com.mybharat.tests.vo.YouthApplyOnVOTest"/>
        </classes>
    </test>

</suite>
