<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Youth Module Suite - runs sequentially on SAME browser.
  
  Flow: Registration → Profile → Certificate Download → Quiz
  
  Run with:
    mvn test -Denv=prod -Dbrowser=firefox -Dsurefire.suiteXmlFiles=testSuites/testng-youth.xml
    mvn test -Denv=beta -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-youth.xml
-->
<suite name="Youth Module" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Step 1: Registration (opens browser, registers user) -->
    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.YouthRegistrationTest"/>
        </classes>
    </test>

    <!-- Step 2: Youth Profile (same browser, completes full profile after registration) -->
    <test name="Youth Profile Completion">
        <classes>
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
        </classes>
    </test>

    <!-- Step 3: Certificate Download (same browser, downloads registration certificate) -->
    <test name="Registration Certificate Verification">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationCertificateVerificationTest"/>
        </classes>
    </test>

    <!-- Step 4: Quiz Attempt (same browser, attempts competitive quiz) -->
    <test name="Quiz Attempt">
        <classes>
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

</suite>
