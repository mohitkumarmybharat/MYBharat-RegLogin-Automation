<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Create Youth Club Only (skips member registration).
  Uses existing members from Youth_<env>.xlsx YouthClubMembers sheet.

  Run:
    mvn test "-Denv=prod" "-Dbrowser=chrome" "-Dsurefire.suiteXmlFiles=testSuites/testng-create-youthclub.xml"
-->
<suite name="Create Youth Club" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Create Youth Club Organization">
        <classes>
            <class name="com.mybharat.tests.org.CreateYouthClubTest"/>
        </classes>
    </test>

</suite>
