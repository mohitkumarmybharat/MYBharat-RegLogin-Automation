<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  VO Image Approval - Org side reviews youth-uploaded images on an event.

  Flow:
    Step 1: Login as VO Partner (from Partner_prod.xlsx)
    Step 2: Scroll down → View More → Click org name → Events sidebar
            → Search event (second-last from Event_Name.xlsx)
            → Click event card → Images by Youth tab
            → Reject 1st card → Approve 2nd card

  Run:
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-vo-image-approval.xml
-->
<suite name="VO Image Approval" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Step 1: Login as VO Partner user -->
    <test name="VO Login">
        <classes>
            <class name="com.mybharat.tests.vo.VOLoginTest"/>
        </classes>
    </test>

    <!-- Step 2: Navigate to event → Images by Youth → Reject 1st → Approve 2nd -->
    <test name="VO Image Approval">
        <classes>
            <class name="com.mybharat.tests.vo.VOImageApprovalTest"/>
        </classes>
    </test>

</suite>
